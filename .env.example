# 复制为 .env.local 后填入真实值（勿提交含密钥的 .env.local）
# 与 Supabase / Vercel 项目环境变量一致（Dashboard → Project Settings → API）

SUPABASE_URL=https://auuuhejmiynzjpqorvuv.supabase.co
SUPABASE_PUBLISHABLE_KEY=你的publishable密钥
SUPABASE_SECRET_KEY=你的secret密钥
SUPABASE_JWKS_URL=https://auuuhejmiynzjpqorvuv.supabase.co/auth/v1/.well-known/jwks.json

# SUPABASE_PUBLISHABLE_KEY：公开侧能力，受 RLS 约束（等同旧版 anon key）；仅服务端 BFF 使用，禁止 NEXT_PUBLIC_
# SUPABASE_SECRET_KEY：仅服务端，可绕过 RLS（等同旧版 service_role）；禁止 NEXT_PUBLIC_
# SUPABASE_JWKS_URL：校验 Auth JWT 时使用；由 SUPABASE_URL 派生，一般无需手改
# migration 仍走 supabase link + pnpm db:migrate，不依赖 POSTGRES_* 连接串

# Send SMS Hook（Supabase Dashboard → Authentication → Hooks → Send SMS）
SEND_SMS_HOOK_SECRET=v1,whsec_你的Hook密钥
# 可选别名（与 SEND_SMS_HOOK_SECRET 二选一）
# SEND_SMS_HOOK_SECRETS=v1,whsec_你的Hook密钥

# 阿里云号码认证服务（SendSmsVerifyCode）
ALIYUN_ACCESS_KEY_ID=你的AccessKeyId
ALIYUN_ACCESS_KEY_SECRET=你的AccessKeySecret
# 可选：默认 速通互联验证码 / 100001 / 5 分钟
# ALIYUN_SMS_SIGN_NAME=速通互联验证码
# ALIYUN_SMS_TEMPLATE_CODE=100001
# ALIYUN_SMS_VALID_MINUTES=5
