{
  "$comment": "AUTO-GENERATED — 请勿手改。修改 lib/openapi/schemas/* 后执行 pnpm openapi:emit",
  "openapi": "3.0.3",
  "info": {
    "title": "智赢媒体助手 Web BFF API",
    "version": "0.2.0",
    "description": "官网前端 BFF 接口：认证（`/api/web/auth/*`）与账号（`/api/web/account`）。登录成功后由 BFF 写入 HttpOnly Cookie（`qm_access_token`、`qm_refresh_token`），SameSite=Lax，生产环境 Secure。"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "本地开发"
    }
  ],
  "tags": [
    {
      "name": "Web Auth",
      "description": "手机号 OTP 登录与会话管理"
    },
    {
      "name": "Web Account",
      "description": "账号中心与会员权益"
    }
  ],
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "qm_access_token",
        "description": "官网 HttpOnly 会话 Cookie（qm_access_token、qm_refresh_token）"
      }
    },
    "schemas": {
      "AuthOk": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "enum": [
              true
            ]
          }
        },
        "required": [
          "ok"
        ],
        "additionalProperties": false
      },
      "AuthError": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "enum": [
              false
            ]
          },
          "code": {
            "$ref": "#/components/schemas/AuthErrorCode"
          },
          "error": {
            "type": "string"
          },
          "retryAfter": {
            "type": "integer",
            "description": "RATE_LIMITED 时剩余等待秒数"
          }
        },
        "required": [
          "ok",
          "code",
          "error"
        ],
        "additionalProperties": false
      },
      "AuthErrorCode": {
        "type": "string",
        "enum": [
          "INVALID_PHONE",
          "INVALID_OTP",
          "INVALID_REQUEST",
          "RATE_LIMITED",
          "SERVER_ERROR"
        ]
      },
      "SignInPhoneRequest": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "pattern": "^1[3-9]\\d{9}$",
            "description": "11 位中国大陆手机号（不含 +86）",
            "example": "13812345678"
          }
        },
        "required": [
          "phone"
        ],
        "additionalProperties": false
      },
      "VerifyOtpRequest": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "pattern": "^1[3-9]\\d{9}$",
            "description": "11 位中国大陆手机号（不含 +86）",
            "example": "13812345678"
          },
          "token": {
            "type": "string",
            "pattern": "^\\d{6}$",
            "description": "6 位短信验证码",
            "example": "123456"
          }
        },
        "required": [
          "phone",
          "token"
        ],
        "additionalProperties": false
      },
      "MeResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/MeLoggedOut"
          },
          {
            "$ref": "#/components/schemas/MeLoggedIn"
          }
        ],
        "discriminator": {
          "propertyName": "loggedIn",
          "mapping": {
            "false": "#/components/schemas/MeLoggedOut",
            "true": "#/components/schemas/MeLoggedIn"
          }
        }
      },
      "MeLoggedOut": {
        "type": "object",
        "properties": {
          "loggedIn": {
            "type": "boolean",
            "enum": [
              false
            ]
          }
        },
        "required": [
          "loggedIn"
        ],
        "additionalProperties": false
      },
      "MeLoggedIn": {
        "type": "object",
        "properties": {
          "loggedIn": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "phoneMasked": {
            "type": "string",
            "description": "脱敏手机号，如 138****5678",
            "example": "138****5678"
          }
        },
        "required": [
          "loggedIn",
          "userId",
          "phoneMasked"
        ],
        "additionalProperties": false
      },
      "AccountResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/AccountLoggedOut"
          },
          {
            "$ref": "#/components/schemas/AccountLoggedIn"
          }
        ],
        "discriminator": {
          "propertyName": "loggedIn",
          "mapping": {
            "false": "#/components/schemas/AccountLoggedOut",
            "true": "#/components/schemas/AccountLoggedIn"
          }
        }
      },
      "AccountLoggedOut": {
        "type": "object",
        "properties": {
          "loggedIn": {
            "type": "boolean",
            "enum": [
              false
            ]
          }
        },
        "required": [
          "loggedIn"
        ],
        "additionalProperties": false
      },
      "AccountLoggedIn": {
        "type": "object",
        "properties": {
          "loggedIn": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "phoneMasked": {
            "type": "string",
            "example": "138****5678"
          },
          "registeredAt": {
            "type": "string",
            "format": "date-time"
          },
          "entitlement": {
            "$ref": "#/components/schemas/EntitlementSnapshot"
          }
        },
        "required": [
          "loggedIn",
          "userId",
          "phoneMasked",
          "registeredAt",
          "entitlement"
        ],
        "additionalProperties": false
      },
      "EntitlementSnapshot": {
        "type": "object",
        "properties": {
          "plan": {
            "$ref": "#/components/schemas/Plan"
          },
          "planLabel": {
            "type": "string",
            "example": "Pro 会员"
          },
          "status": {
            "$ref": "#/components/schemas/EntitlementStatus"
          },
          "expiresAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Pro/Enterprise 到期时间；free 为 null"
          },
          "enrolledAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "plan",
          "planLabel",
          "status",
          "expiresAt",
          "enrolledAt"
        ],
        "additionalProperties": false
      },
      "Plan": {
        "type": "string",
        "enum": [
          "free",
          "pro",
          "enterprise"
        ]
      },
      "EntitlementStatus": {
        "type": "string",
        "enum": [
          "active",
          "expired",
          "revoked"
        ]
      },
      "AccountError": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "enum": [
              false
            ]
          },
          "code": {
            "$ref": "#/components/schemas/AccountErrorCode"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "ok",
          "code",
          "error"
        ],
        "additionalProperties": false
      },
      "AccountErrorCode": {
        "type": "string",
        "enum": [
          "SERVICE_UNAVAILABLE",
          "SERVER_ERROR"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/web/auth/sign-in/phone": {
      "post": {
        "tags": [
          "Web Auth"
        ],
        "summary": "发送短信验证码",
        "description": "触发 Supabase signInWithOtp，经 Send SMS Hook 发送 6 位短信验证码。同号 BFF 层 30s 内重复请求返回 429。",
        "operationId": "signInPhone",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInPhoneRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "验证码已发送",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthOk"
                }
              }
            }
          },
          "400": {
            "description": "请求非法或手机号格式错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          },
          "429": {
            "description": "发码过于频繁",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          },
          "500": {
            "description": "服务异常",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          }
        }
      }
    },
    "/api/web/auth/sign-in/phone/verify": {
      "post": {
        "tags": [
          "Web Auth"
        ],
        "summary": "校验 OTP 并登录",
        "description": "校验 6 位 OTP 并建立官网会话。成功响应头含 Set-Cookie（access + refresh token）。验证成功后服务端幂等创建 user profile（公测期授予 Pro）。",
        "operationId": "verifyPhoneOtp",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyOtpRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功，响应头含 Set-Cookie",
            "headers": {
              "Set-Cookie": {
                "description": "qm_access_token 与 qm_refresh_token",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthOk"
                }
              }
            }
          },
          "400": {
            "description": "请求非法、手机号错误或验证码无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          },
          "500": {
            "description": "服务异常",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          }
        }
      }
    },
    "/api/web/auth/me": {
      "get": {
        "tags": [
          "Web Auth"
        ],
        "summary": "读取当前登录态",
        "description": "携带官网会话 Cookie。服务端会在 access token 即将过期时自动 refreshSession 并回写 Cookie；刷新失败时清除 Cookie 并返回 loggedIn: false。",
        "operationId": "getMe",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "当前登录态",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/web/auth/logout": {
      "post": {
        "tags": [
          "Web Auth"
        ],
        "summary": "退出登录",
        "description": "清除官网会话 Cookie；best-effort 调用 Supabase signOut。",
        "operationId": "logout",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "已退出",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthOk"
                }
              }
            }
          }
        }
      }
    },
    "/api/web/account": {
      "get": {
        "tags": [
          "Web Account"
        ],
        "summary": "读取账号与会员权益",
        "description": "携带官网会话 Cookie。若 profile 不存在则幂等创建。status 在 expires_at 过期时对 pro/enterprise 读时派生为 expired。",
        "operationId": "getAccount",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "账号信息或未登录",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "503": {
            "description": "数据库或服务不可用",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountError"
                }
              }
            }
          }
        }
      }
    }
  }
}
